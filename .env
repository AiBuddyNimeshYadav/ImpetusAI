# ImpetusAI Workplace Platform Environment Variables

APP_NAME=ImpetusAI Workplace Platform
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./impetusai.db

# Auth
SECRET_KEY=change-me-in-production-generate-a-64-char-random-hex
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Provider
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash

# API Keys
# AIzaSyBLhbdDKS1X2pMZ30TczeJInWK7ssD0ZdI
GEMINI_API_KEY=AIzaSyBLhbdDKS1X2pMZ30TczeJInWK7ssD0ZdI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# RAG Settings
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3

# Document Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
