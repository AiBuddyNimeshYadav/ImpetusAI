# ═══════════════════════════════════════════════════════════════════
# ImpetusAI Workplace Platform — Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────
APP_NAME=ImpetusAI Workplace Platform
APP_VERSION=0.1.0
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (SQLite for MVP, switch to PostgreSQL for prod) ────
DATABASE_URL=sqlite+aiosqlite:///./impetusai.db

# ── Auth (CHANGE SECRET_KEY IN PRODUCTION!) ─────────────────────
SECRET_KEY=change-me-in-production-generate-a-64-char-random-hex
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM Provider (SINGLE SWAP POINT) ──────────────────────────
# Options: gemini, ollama, claude, openai
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash

# ── API Keys (set the one matching your LLM_PROVIDER) ──────────
GEMINI_API_KEY="AIzaSyAr65Y6x2TQ6VkkqbBqrANNQ_XPa_EX2ao"
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama (only needed if LLM_PROVIDER=ollama) ───────────────
OLLAMA_BASE_URL=http://localhost:11434
# Popular models: ollama/mistral, ollama/llama3.1, ollama/phi3

# ── LLM Fallback (optional) ───────────────────────────────────
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=

# ── Embeddings ─────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── RAG Settings ───────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3

# ── Document Upload ────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ── Admin Bootstrap ─────────────────────────────────────────────
# Created automatically on first startup if no admin user exists
ADMIN_EMAIL=admin@impetus.com
ADMIN_PASSWORD=ChangeMe123!
